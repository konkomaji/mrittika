{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1140px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"custom": true,
			"customGradient": true,
			"palette": [
				{ "slug": "ink", "color": "#0a0a0a", "name": "Ink" },
				{ "slug": "near-black", "color": "#141414", "name": "Near Black" },
				{ "slug": "graphite", "color": "#1f1f1f", "name": "Graphite" },
				{ "slug": "charcoal", "color": "#2e2e2e", "name": "Charcoal" },
				{ "slug": "slate", "color": "#525252", "name": "Slate" },
				{ "slug": "ash", "color": "#737373", "name": "Ash" },
				{ "slug": "silver", "color": "#a3a3a3", "name": "Silver" },
				{ "slug": "smoke", "color": "#d4d4d4", "name": "Smoke" },
				{ "slug": "fog", "color": "#e7e7e7", "name": "Fog" },
				{ "slug": "paper", "color": "#f5f5f5", "name": "Paper" },
				{ "slug": "white", "color": "#ffffff", "name": "White" }
			],
			"gradients": [
				{ "slug": "ink-fade", "gradient": "linear-gradient(180deg, #0a0a0a 0%, #2e2e2e 100%)", "name": "Ink Fade" },
				{ "slug": "paper-fade", "gradient": "linear-gradient(180deg, #ffffff 0%, #e7e7e7 100%)", "name": "Paper Fade" }
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"customFontSize": true,
			"lineHeight": true,
			"dropCap": false,
			"fontFamilies": [
				{
					"slug": "display",
					"name": "Display (Poppins)",
					"fontFamily": "\"Poppins\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Noto Sans Bengali\", sans-serif"
				},
				{
					"slug": "body",
					"name": "Body (Inter)",
					"fontFamily": "\"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Noto Sans Bengali\", Helvetica, Arial, sans-serif"
				},
				{
					"slug": "mono",
					"name": "Mono",
					"fontFamily": "\"SF Mono\", \"Cascadia Code\", \"Roboto Mono\", ui-monospace, Menlo, Consolas, monospace"
				}
			],
			"fontSizes": [
				{ "slug": "small", "name": "Small", "size": "0.875rem", "fluid": false },
				{ "slug": "medium", "name": "Medium", "size": "1rem", "fluid": false },
				{ "slug": "large", "name": "Large", "size": "1.25rem", "fluid": { "min": "1.125rem", "max": "1.375rem" } },
				{ "slug": "x-large", "name": "Extra Large", "size": "1.75rem", "fluid": { "min": "1.5rem", "max": "2rem" } },
				{ "slug": "xx-large", "name": "Display", "size": "2.75rem", "fluid": { "min": "2rem", "max": "3.25rem" } },
				{ "slug": "huge", "name": "Hero", "size": "4rem", "fluid": { "min": "2.5rem", "max": "4.5rem" } }
			]
		},
		"spacing": {
			"customSpacingSize": true,
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"spacingScale": { "steps": 0 },
			"spacingSizes": [
				{ "slug": "20", "name": "1 · XS", "size": "0.5rem" },
				{ "slug": "30", "name": "2 · S", "size": "1rem" },
				{ "slug": "40", "name": "3 · M", "size": "1.5rem" },
				{ "slug": "50", "name": "4 · L", "size": "2.5rem" },
				{ "slug": "60", "name": "5 · XL", "size": "4rem" },
				{ "slug": "70", "name": "6 · XXL", "size": "6rem" }
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{ "slug": "sm", "name": "Small", "shadow": "0 1px 2px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.10)" },
				{ "slug": "md", "name": "Medium", "shadow": "0 2px 6px rgba(0,0,0,0.08), 0 4px 12px rgba(0,0,0,0.08)" },
				{ "slug": "lg", "name": "Large", "shadow": "0 8px 24px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.08)" },
				{ "slug": "xl", "name": "Expressive", "shadow": "0 16px 48px rgba(0,0,0,0.16), 0 6px 16px rgba(0,0,0,0.10)" }
			]
		},
		"dimensions": { "minHeight": true, "aspectRatio": true },
		"position": { "sticky": true }
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "1.0625rem",
			"lineHeight": "1.7"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": { "top": "0", "right": "var(--wp--preset--spacing--30)", "bottom": "0", "left": "var(--wp--preset--spacing--30)" }
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "700",
					"lineHeight": "1.15",
					"letterSpacing": "-0.02em"
				}
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)" } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--large)" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--ink)" },
				"typography": { "textDecoration": "underline" },
				":hover": { "color": { "text": "var(--wp--preset--color--slate)" } }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--ink)",
					"text": "var(--wp--preset--color--white)"
				},
				"border": { "radius": "999px" },
				"spacing": { "padding": { "top": "0.75rem", "bottom": "0.75rem", "left": "1.5rem", "right": "1.5rem" } },
				"typography": { "fontWeight": "600", "textDecoration": "none" },
				":hover": { "color": { "background": "var(--wp--preset--color--charcoal)" } }
			}
		},
		"blocks": {
			"core/post-title": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)" } },
			"core/quote": {
				"border": { "left": { "color": "var(--wp--preset--color--ink)", "width": "3px", "style": "solid" } },
				"typography": { "fontStyle": "italic" }
			},
			"core/code": {
				"color": { "background": "var(--wp--preset--color--paper)" },
				"typography": { "fontFamily": "var(--wp--preset--font-family--mono)" }
			}
		}
	},
	"customTemplates": [
		{ "name": "page-wide", "title": "Wide / Full-Width Page", "postTypes": ["page"] }
	],
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	]
}

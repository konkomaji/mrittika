# Normalize line endings to LF in the repo for all text.
* text=auto eol=lf

*.php text eol=lf
*.css text eol=lf
*.js  text eol=lf
*.json text eol=lf
*.md  text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary

# Keep release archives lean — exclude dev files from `git archive` / GitHub zips.
/.github       export-ignore
.gitattributes export-ignore
.gitignore     export-ignore
CHANGELOG.md   export-ignore
README.md      export-ignore
